# =============================================================================
# Environment Variable Reference — Sensitivity Classification
# =============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Store HIGH-sensitivity values in GitHub Secrets / Vault / your cloud
# provider's secret manager — not in plaintext files on developer machines.
#
# Sensitivity levels used here:
#   LOW    — safe to log, share in tickets, or store unencrypted in CI env vars
#   MEDIUM — treat like a password: do not log, rotate on breach, but not a
#             root credential
#   HIGH   — treat like a private key: store in Vault/Secrets Manager, rotate
#             immediately on breach, never pass as a CLI argument or log
#
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity
# NODE_ENV       — LOW sensitivity
#                  Controls framework behaviour (error verbosity, Swagger, etc.)
#                  Values: development | test | production
# -----------------------------------------------------------------------------
NODE_ENV=development

# PORT           — LOW sensitivity
#                  TCP port the HTTP server binds to inside the container.
#                  The container port is remapped by the orchestrator; this
#                  value is not externally visible.
# -----------------------------------------------------------------------------
PORT=3000

# ENABLE_SWAGGER — LOW sensitivity
#                  Set to true ONLY in development/local environments.
#                  Swagger UI exposes full API schema — never enable in prod.
# -----------------------------------------------------------------------------
ENABLE_SWAGGER=false

# -----------------------------------------------------------------------------
# Supabase
# SUPABASE_URL              — LOW sensitivity
#                             Public HTTPS endpoint for your Supabase project.
#                             Visible in Supabase dashboard Settings > API.
# SUPABASE_ANON_KEY         — MEDIUM sensitivity
#                             JWT signed with the project's anon role. Safe for
#                             server-side use because RLS policies apply. Do not
#                             expose to end-user browsers from this service.
# SUPABASE_SERVICE_ROLE_KEY — HIGH sensitivity
#                             Bypasses all Row Level Security. Full database
#                             access with no restrictions. Store in Vault or
#                             GitHub Secrets — never in a .env file committed
#                             to any repository.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Optional: deep-link or frontend URL where Supabase should send password-reset users
# after they click the email link. For mobile apps, this is usually a custom scheme
# like pakiship://reset-password.
SUPABASE_PASSWORD_RESET_REDIRECT_URL=pakiship://reset-password

# -----------------------------------------------------------------------------
# CORS
# ALLOWED_ORIGINS — LOW sensitivity
#                   Comma-separated list of browser origins permitted to call
#                   this API. Example: http://localhost:5173,https://app.example.com
#                   No wildcard (*) is accepted — the CORS factory enforces
#                   exact-match whitelisting.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# -----------------------------------------------------------------------------
# APICenter integration (optional for local dev — service starts without these
# but API-proxying features will be unavailable)
#
# API_CENTER_BASE_URL — LOW sensitivity
#                       Internal service URL for the APICenter gateway.
#                       Example: https://apicenter.internal
# API_CENTER_API_KEY  — HIGH sensitivity
#                       Bearer token used to authenticate requests to APICenter.
#                       Store in Vault or GitHub Secrets.
# -----------------------------------------------------------------------------
API_CENTER_BASE_URL=https://apicenter.example.com
API_CENTER_API_KEY=your-api-center-key-here

# =============================================================================
# Replit pre-production preview — environment variable instructions
# =============================================================================
#
# When running on Replit (test branch preview only), do NOT create a .env file.
# Set all variables below via the Replit Secrets UI (Tools > Secrets) instead.
# Secrets are injected as environment variables at runtime and are never
# committed to the repository.
#
# Variables to configure in Replit Secrets:
#
#   NODE_ENV                = production
#   PORT                    = 3000
#   ENABLE_SWAGGER          = false
#   SUPABASE_URL            = https://your-project.supabase.co
#   SUPABASE_ANON_KEY       = <your anon key>
#   SUPABASE_SERVICE_ROLE_KEY = <your service role key>
#   API_CENTER_BASE_URL     = <your APICenter URL if needed>
#   API_CENTER_API_KEY      = <your APICenter key if needed>
#
#   ALLOWED_ORIGINS — add your Replit preview URL here. Pattern examples:
#     https://<repl-name>.<username>.repl.co
#     https://<repl-name>--3000.<username>.repl.co
#   Use a comma-separated list if multiple frontend origins need access.
#   Do NOT use a bare wildcard (*) — the CORS factory enforces exact matching.
#
# This environment is for pre-production preview on the test branch only.
# UAT and production deployments use Kubernetes on AWS EKS with secrets
# managed via AWS Secrets Manager / external-secrets-operator.
# =============================================================================
